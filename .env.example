BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=123456789,987654321

# Court settings
COURT_TYPE=iqtisodiy
# tashkent | all
REGION_MODE=tashkent

# Scheduler (Tashkent time = UTC+5)
SCHEDULE_HOUR=5
SCHEDULE_MINUTE=0

# Request throttling (seconds)
REQUEST_DELAY_MIN=3
REQUEST_DELAY_MAX=7

# DB paths
ACTIVE_DB_PATH=data/active.db
ARCHIVE_DB_PATH=data/archive.db
